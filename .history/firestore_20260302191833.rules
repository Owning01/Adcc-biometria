rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // UID del Admin Principal
    function isAdmin() {
      return request.auth != null && request.auth.uid == "N9vLq7NiGwOWsOkp5m9SUT4vzOw1";
    }

    // Dev: mismo UID pero identificado por email, o admin directo
    // En Firestore Rules podemos verificar el token del usuario
    function isDev() {
      return request.auth != null && (
        request.auth.token.email == "dev@admin.com" ||
        request.auth.token.email == "admin@admin.com"
      );
    }

    // Admin O Dev (Dev tiene todos los permisos del Admin y más)
    function isAdminOrDev() {
      return isAdmin() || isDev();
    }

    // Usuario autenticado cualquiera
    function isAuthed() {
      return request.auth != null;
    }

    // ----------------------------------------------------------
    // Colección de Equipos (Metadatos y Logos)
    // Lectura pública, escritura solo admin/dev
    // ----------------------------------------------------------
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdminOrDev();
    }

    // ----------------------------------------------------------
    // Colección de Torneos
    // Lectura pública, escritura solo admin/dev
    // ----------------------------------------------------------
    match /tournaments/{document=**} {
      allow read: if true;
      allow write: if isAdminOrDev();
    }

    // ----------------------------------------------------------
    // Colección de Partidos
    // Lectura pública, escritura: admin/dev pueden todo,
    // árbitros autenticados pueden actualizar (para marcar goles etc)
    // ----------------------------------------------------------
    match /matches/{document=**} {
      allow read: if true;
      allow write: if isAdminOrDev() || isAuthed();
    }

    // ----------------------------------------------------------
    // Colección de Usuarios
    // ----------------------------------------------------------
    match /users/{document=**} {
      allow read: if true;
      allow write: if isAdminOrDev();
    }
    
    match /users_v2/{document=**} {
      allow read: if true;
      allow write: if isAdminOrDev();
    }

    // ----------------------------------------------------------
    // Colección de Auditoría
    // ----------------------------------------------------------
    match /audit_logs/{logId} {
      allow create: if isAuthed();
      allow read: if isAdminOrDev();
    }

    // ----------------------------------------------------------
    // Regla de fallback: solo admin/dev para todo lo demás
    // ----------------------------------------------------------
    match /{document=**} {
      allow read, write: if isAdminOrDev();
    }
  }
}
