rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si es admin
    function isAdmin() {
       return request.auth != null && request.auth.uid == "N9vLq7NiGwOWsOkp5m9SUT4vzOw1";
    }

    // Función auxiliar para verificar si es usuario autenticado
    function isAuthed() {
       return request.auth != null;
    }

    // Colección de Equipos (Metadatos y Logos) - lectura pública, escritura autenticada
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // Colección de Torneos - totalmente abierta para operación en vivo
    match /tournaments/{document=**} {
      allow read, write: if true;
    }

    // Colección de Partidos - totalmente abierta para operación en vivo
    match /matches/{document=**} {
      allow read, write: if true;
    }

    // Colección de Usuarios
    match /users/{document=**} {
      allow read: if true;
      allow write: if isAuthed();
    }
    
    match /users_v2/{document=**} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // Colección de Auditoría
    match /audit_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Regla de fallback: solo admin tiene acceso a colecciones no listadas arriba
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
