rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Función auxiliar para verificar si es admin o dev
    function isAdminOrDev() {
       return request.auth != null && (
         request.auth.uid == "N9vLq7NiGwOWsOkp5m9SUT4vzOw1" ||
         request.auth.token.email == "dev@admin.com" ||
         request.auth.token.email == "admin@admin.com"
       );
    }

    // Reglas para logos de equipos
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOrDev();
    }

    // Reglas por defecto
    match /{allPaths=**} {
      allow read, write: if isAdminOrDev();
    }
  }
}
